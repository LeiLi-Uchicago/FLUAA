nextflow.enable.dsl = 2

params {
  outdir = 'results'
  insertion_min_support = 100
  dedupe_mode = 'best_sequence'
  date_column = 'Collection_Date'
  id_column = 'Isolate_Id'
  max_records_test = 0
  nextclade_env = "${projectDir}/envs/flu_pipeline.yml"
  nextclade_cmd = 'nextclade3'
  python_cmd = 'python'
  python_env = "${projectDir}/envs/flu_pipeline.yml"
  h1n1_split_lineage = false
  h1n1_seasonal_datasets = [:]
  // Max per-site HA divergence for a lineage call to be trusted (pdm09 and
  // seasonal HA differ ~22%, so a "win" near that distance is not a real match).
  h1n1_max_divergence_frac = 0.15
  // pdm09-classified isolates collected before this year are filtered out
  // (seasonal H1N1 stopped circulating in humans after the 2009 pandemic).
  h1n1_pdm_min_year = 2009
  h5_ha_dataset = 'community/moncla-lab/iav-h5/ha/all-clades'
  h5_na_nextclade_datasets = [:]
  h5_na_fallback = false
}

profiles {
  H1N1 {
    params.subtype = 'H1N1'
    params.input_dir = "${projectDir}/H1N1"
    params.outdir = "${params.outdir}/H1N1"
    // Assign each isolate to seasonal or pdm09 from its HA sequence, then map each
    // lineage against its own reference set and keep the two separate throughout.
    // pdm09 -> Nextclade pdm09 references; seasonal -> custom A/USSR/90/1977 refs.
    params.h1n1_split_lineage = true
    params.datasets = [
      HA:  'flu_h1n1pdm_ha',
      NA:  'flu_h1n1pdm_na',
      MP:  'nextstrain/flu/h1n1pdm/mp',
      NP:  'nextstrain/flu/h1n1pdm/np',
      NS:  'nextstrain/flu/h1n1pdm/ns',
      PA:  'nextstrain/flu/h1n1pdm/pa',
      PB1: 'nextstrain/flu/h1n1pdm/pb1',
      PB2: 'nextstrain/flu/h1n1pdm/pb2'
    ]
    // Custom seasonal H1N1 Nextclade datasets (local directories under refs/),
    // built from A/USSR/90/1977 (EPI_ISL_66104) for all eight segments.
    params.h1n1_seasonal_datasets = [
      HA:  "${projectDir}/refs/ussr77_h1n1_ha",
      NA:  "${projectDir}/refs/ussr77_h1n1_na",
      MP:  "${projectDir}/refs/ussr77_h1n1_mp",
      NP:  "${projectDir}/refs/ussr77_h1n1_np",
      NS:  "${projectDir}/refs/ussr77_h1n1_ns",
      PA:  "${projectDir}/refs/ussr77_h1n1_pa",
      PB1: "${projectDir}/refs/ussr77_h1n1_pb1",
      PB2: "${projectDir}/refs/ussr77_h1n1_pb2"
    ]
    // pdm09: include clades. Seasonal: year-month only (no clades).
    params.clade_columns = ['HA_clade', 'HA_short_clade', 'HA_legacy_clade', 'NA_clade']
    params.seasonal_clade_columns = []
  }

  H3N2 {
    params.subtype = 'H3N2'
    params.input_dir = "${projectDir}/H3N2"
    params.outdir = "${params.outdir}/H3N2"
    params.datasets = [
      HA:  'nextstrain/flu/h3n2/ha/EPI1857216',
      NA:  'nextstrain/flu/h3n2/na/EPI1857215',
      MP:  'nextstrain/flu/h3n2/mp',
      NP:  'nextstrain/flu/h3n2/np',
      NS:  'nextstrain/flu/h3n2/ns',
      PA:  'nextstrain/flu/h3n2/pa',
      PB1: 'nextstrain/flu/h3n2/pb1',
      PB2: 'nextstrain/flu/h3n2/pb2'
    ]
    params.clade_columns = ['HA_clade', 'HA_short_clade', 'HA_legacy_clade', 'NA_clade']
  }

  B_VIC {
    params.subtype = 'B_VIC'
    params.input_dir = "${projectDir}/B_VIC"
    params.outdir = "${params.outdir}/B_VIC"
    params.datasets = [
      HA:  'nextstrain/flu/vic/ha/KX058884',
      NA:  'nextstrain/flu/vic/na/CY073894',
      MP:  'nextstrain/flu/vic/mp',
      NP:  'nextstrain/flu/vic/np',
      NS:  'nextstrain/flu/vic/ns',
      PA:  'nextstrain/flu/vic/pa',
      PB1: 'nextstrain/flu/vic/pb1',
      PB2: 'nextstrain/flu/vic/pb2'
    ]
    params.clade_columns = ['HA_clade', 'HA_legacy_clade', 'NA_clade']
  }

  B_YAM {
    params.subtype = 'B_YAM'
    params.input_dir = "${projectDir}/B_YAM"
    params.outdir = "${params.outdir}/B_YAM"
    params.datasets = [
      HA:  'nextstrain/flu/yam/ha/JN993010',
      NA:  'nextstrain/flu/b/na/CY073894',
      MP:  'nextstrain/flu/b/mp',
      NP:  'nextstrain/flu/b/np',
      NS:  'nextstrain/flu/b/ns',
      PA:  'nextstrain/flu/b/pa',
      PB1: 'nextstrain/flu/b/pb1',
      PB2: 'nextstrain/flu/b/pb2'
    ]
    params.clade_columns = ['HA_clade']
  }

  H5NX {
    params.subtype = 'H5NX'
    params.input_dir = "${projectDir}/h5_example"
    params.outdir = "${params.outdir}/H5NX"
    params.h5_na_fallback = true
    params.datasets = [
      HA:  params.h5_ha_dataset,
      MP:  'nextstrain/flu/h2n2/mp',
      NP:  'nextstrain/flu/h2n2/np',
      NS:  'nextstrain/flu/h2n2/ns',
      PA:  'nextstrain/flu/h2n2/pa',
      PB1: 'nextstrain/flu/h2n2/pb1',
      PB2: 'nextstrain/flu/h2n2/pb2'
    ]
    params.h5_na_nextclade_datasets = [
      N1: 'nextstrain/flu/h1n1pdm/na/MW626056',
      N2: 'nextstrain/flu/h2n2/na'
    ]
    params.clade_columns = ['HA_clade', 'NA_subtype', 'Pathogenicity']
  }
}

process {
  errorStrategy = 'terminate'
  cpus = 2
  memory = '8 GB'
}

conda {
  createOptions = '--solver classic'
}
